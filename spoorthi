class PascalTriangle {
    public static void main(String[] args) {
        int i, j, x, n = 5;

        for(i = 0; i < n; i++) {
            x = 1;

            for(j = 0; j < n - i; j++) {
                System.out.print("  ");
            }

            for(j = 0; j <= i; j++) {
                System.out.print("*" + "   ");
                x = x * (i - j) / (j + 1);
            }

            System.out.println();
        }
    }
}